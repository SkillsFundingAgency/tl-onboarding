<script>
    document.title = "Contact us | {{settings.service_name}}"

</script>



<!-- Main content -->
<main id="main-content" role="main">

    <div class="govuk-width-container">
        <div id="tl-breadcrumbs--help">
            <div class="tl-breadcrumbs">
                {{breadcrumbs}}
            </div>
        </div>
    </div>

    <div class="govuk-width-container govuk-main-wrapper">

        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                <h1 class="govuk-heading-xl">Contact us</h1>
                <p class="govuk-body">Use this form to send a message to the Department for Education (DfE) about T
                    Levels. You can usually expect a reply within 2 working days. </p>
                <p class="govuk-body">Before you send a question, check to see if it has been answered in the {{#link
                    'posts' class='govuk-link' }}T Level discussion forum{{/link}}</p>
                <div class="tl-ticket--form">
                    {{request_form}}
                </div>
            </div>
        </div>

        <div class="govuk-grid-row">
            <h2 class="govuk-heading-s">
                These articles might help with your query:
            </h2>

            <ul class="govuk-list govuk-list--bullet">
                <li>
                    <a href="https://support.tlevels.gov.uk/hc/en-gb/articles/10635942624658-Add-the-Connect-with-employers-interested-in-T-Levels-to-your-DfE-sign-in-account-today"
                        class="govuk-link">Connect with employers interested in T Levels service</a>
                </li>
                <li>
                    <a href="/hc/en-gb/articles/https://support.tlevels.gov.uk/hc/en-gb/articles/29182807345298-Employer-Support-Fund-FY25-26-Online-claims-tool"
                        class="govuk-link">Employer Support Fund – Online claims tool</a>
                </li>
                <li>
                    <a href="/hc/en-gb/articles/https://support.tlevels.gov.uk/hc/en-gb/articles/11397253815186-About-the-Manage-T-Level-Results-service"
                        class="govuk-link">The Manage T Level Results service</a>
                </li>
                <li>
                    <a href="/hc/en-gb/categories/https://support.tlevels.gov.uk/hc/en-gb/articles/360020077859-Update-your-T-Level-course-information-now"
                        class="govuk-link">Update your T Level course information</a>
                </li>
            </ul>
        </div>
    </div>
</main>

<script>

    const form_name_field_id = {{ settings.field_id_name }}
    const form_subject_field_id = {{ settings.field_id_subject }}


    $(function () {
        $("input[type='submit']").click(function () {
            event.preventDefault;
            var subjectselect = $(".nesty-input").text();
            $("#request_subject").val(subjectselect);
        });
    });

    $(document).ready(function () {
        if (isLoggedIn()) {
            $.getJSON('/api/v2/users/me.json', function (data) {
                $("#request_custom_fields_360019751459").val(data.user.name);
            });
        };

        $('.form-field.request_custom_fields_' + form_name_field_id).prepend('<h2 class="govuk-heading-m govuk-!-margin-top-7">Your details</h2>');
        $('.form-field.request_custom_fields_' + form_subject_field_id).prepend('<h2 class="govuk-heading-m govuk-!-margin-top-7">Your message</h2>');
        $("input[type='submit']").attr('value', 'Send');


        var NameField = $('input#request_custom_fields_' + form_name_field_id).parent();
        NameField.insertBefore($('input#request_anonymous_requester_email').parent());

        $(".notification-error").each(function () {
            $(this).parent('.form-field').find("label").after(this);
            if (!$(this).parent('.form-field').find('#upload-error').length) {
                $(this).parent('.form-field').addClass("govuk-form-group--error");
            }

        });

        $('label[for="request_anonymous_requester_email"]').text("Email address");

    });

</script>